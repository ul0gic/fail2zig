# Local-only workflow + planning dirs (not committed)
.claude/
.project/

# Build artifacts
zig-out/
zig-cache/
.zig-cache/
node_modules/

# web/ Astro subproject build artifacts
web/dist/
web/.astro/

# Node debug logs (web/)
*.log
npm-debug.log*
pnpm-debug.log*
yarn-debug.log*

# Editor/OS cruft
.DS_Store
*.o
*.d
*.swp

# Editors / IDEs
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
.idea/

# Playwright
.playwright-mcp/

# Secrets
.env

# Accidental artifacts at repo root — this is a Zig project, any
# package.json or lockfile here is from pnpm being run at the wrong
# cwd. Real Node manifests live under web/ only.
/package.json
/pnpm-lock.yaml

# Debug / macOS screenshots. Narrow-no-break-space in macOS filenames,
# so the literal 'Screenshot*.png' pattern is deliberate.
Screenshot*.png
Screenshot*.jpg
Screenshot*.jpeg
