---
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="wrap">
    <div>
      <div class="brand footer-brand">
        <span class="brand-name">fail<span class="brand-2">2</span>zig</span>
      </div>
      <div class="footer-tagline">
        A modern intrusion prevention system. Single binary. Zero dependencies.
      </div>
      <div class="footer-copy">
        <span class="footer-ver">v0.1.0-preview</span><br />
        © {year} ul0gic<br />
        Code licensed under <a href="/LICENSE" class="footer-link">AGPL-3.0-or-later</a>
      </div>
      <div class="footer-privacy">
        Cookieless analytics via Cloudflare.
        <a href="/privacy" class="footer-link">Privacy</a> &middot;
        <a href="/terms" class="footer-link">Terms</a>
      </div>
    </div>
    <div class="foot-cols">
      <div>
        <h5>Product</h5>
        <a href="/">Overview</a>
        <a href="/see-it-live">See it Live</a>
      </div>
      <div>
        <h5>Docs</h5>
        <a href="/docs">Getting started</a>
        <a href="/docs">Migration guide</a>
        <a href="/docs">Configuration</a>
        <a href="/docs">CLI reference</a>
      </div>
      <div>
        <h5>Security</h5>
        <a href="/threat-model">Threat model</a>
        <a href="https://github.com/ul0gic/fail2zig/blob/main/SECURITY.md" rel="noopener noreferrer">Report a vulnerability</a>
        <a href="/docs/guides/verifying-zero-dependencies">Verify a build</a>
        <a href="/changelog">Changelog</a>
      </div>
      <div>
        <h5>Project</h5>
        <a href="/why">Why fail2zig</a>
        <a href="https://github.com/ul0gic/fail2zig" rel="noopener noreferrer">GitHub ↗</a>
      </div>
    </div>
  </div>
</footer>

<style>
  .brand-2 {
    color: var(--accent);
  }
  .footer-brand {
    margin-bottom: 12px;
  }
  .footer-tagline {
    color: var(--fg-mute);
    max-width: 32ch;
    line-height: 1.6;
  }
  .footer-copy {
    margin-top: 20px;
    color: var(--fg-mute);
  }
  .footer-ver {
    color: var(--fg-dim);
    letter-spacing: 0.02em;
  }
  .footer-privacy {
    margin-top: 8px;
    color: var(--fg-mute);
  }
  .footer-link {
    color: var(--fg-dim);
  }
  .footer-link:hover {
    color: var(--accent);
  }
</style>
