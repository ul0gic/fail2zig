---
// Site navigation — extracted verbatim (class names preserved) from
// .project/design/assets/shared.js `renderNav()` and .project/design/index.html.
// Styling lives in src/styles/theme.css under the .site-nav / .nav-inner rules.

interface Props {
  active?: string | undefined;
}

const { active } = Astro.props;

const links: readonly { href: string; label: string }[] = [
  { href: '/', label: 'Home' },
  { href: '/docs', label: 'Docs' },
  { href: '/threat-model', label: 'Threat Model' },
  { href: '/why', label: 'Why' },
  { href: '/see-it-live', label: 'See it Live' },
];

const isActive = (href: string): boolean => {
  if (active) return active === href;
  const path = Astro.url.pathname.replace(/\/$/, '') || '/';
  const target = href.replace(/\/$/, '') || '/';
  return path === target;
};
---

<nav class="site-nav">
  <div class="nav-inner">
    <a href="/" class="brand">
      <span class="brand-name">fail<span class="brand-2">2</span>zig</span>
    </a>
    <div class="nav-links">
      {
        links.map((link) => (
          <a href={link.href} class={isActive(link.href) ? 'active' : ''}>
            {link.label}
          </a>
        ))
      }
    </div>
    <div class="nav-right">
      <a
        href="/changelog"
        class:list={['nav-changelog', { active: isActive('/changelog') }]}
      >
        Changelog
      </a>
      <span class="nav-tag" title="Pre-1.0 preview release">preview</span>
      <a
        href="https://github.com/ul0gic/fail2zig"
        class="nav-cta"
        title="Source, releases, install instructions on GitHub"
        rel="noopener noreferrer">github ↗</a
      >
    </div>
  </div>
</nav>

<style>
  .brand-name {
    font-size: 20px;
  }
  .brand-2 {
    color: var(--accent);
  }
  .nav-changelog {
    font-size: 13px;
  }
  .nav-tag {
    font-family: var(--mono);
    font-size: 10px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--fg-mute);
    border: 1px solid var(--line);
    padding: 2px 7px;
    margin: 0 2px;
    line-height: 1.4;
  }
</style>
