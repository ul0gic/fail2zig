---
import BaseLayout from '@/layouts/BaseLayout.astro';
---

<BaseLayout title="404 — fail2zig" description="Page not found.">
  <div class="notfound">
    <p class="code">404</p>
    <h1>no match in the filter set</h1>
    <p class="lede">
      Whatever you were looking for isn't at this path. It may have moved, or the link may be stale.
      Try one of the routes below.
    </p>
    <ul class="routes">
      <li><a href="/">Home</a> <span class="hint">— overview</span></li>
      <li><a href="/demo">Demo</a> <span class="hint">— live honeypot feed</span></li>
      <li><a href="/docs">Docs</a> <span class="hint">— reference + guides</span></li>
      <li><a href="/why">Why</a> <span class="hint">— the argument</span></li>
      <li>
        <a href="/threat-model">Threat Model</a>
        <span class="hint">— STRIDE + data-flow</span>
      </li>
      <li><a href="/changelog">Changelog</a> <span class="hint">— release history</span></li>
    </ul>
  </div>
</BaseLayout>

<style>
  .notfound {
    max-width: 720px;
    margin: 96px auto 160px;
    padding: 0 32px;
  }
  .code {
    font-family: var(--mono);
    font-size: 12px;
    letter-spacing: 0.12em;
    color: var(--fg-faint);
    text-transform: uppercase;
    margin: 0 0 16px;
  }
  .notfound h1 {
    font-size: 40px;
    font-weight: 500;
    letter-spacing: -0.01em;
    margin: 0 0 24px;
    color: var(--fg);
  }
  .lede {
    font-size: 15px;
    line-height: 1.6;
    color: var(--fg-body);
    margin: 0 0 40px;
    max-width: 56ch;
  }
  .routes {
    list-style: none;
    margin: 0;
    padding: 0;
    font-family: var(--mono);
    font-size: 13px;
    line-height: 1.9;
  }
  .routes a {
    color: var(--fg);
    text-decoration: underline;
    text-decoration-color: var(--accent-ghost);
    text-underline-offset: 3px;
  }
  .routes a:hover {
    text-decoration-color: var(--accent);
    color: var(--accent);
  }
  .routes .hint {
    color: var(--fg-faint);
    margin-left: 8px;
  }
</style>
