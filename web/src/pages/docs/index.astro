---
import { getCollection } from 'astro:content';
import DocLayout from '@/layouts/DocLayout.astro';

const allDocs = await getCollection('docs');

interface SidebarSection {
  label: string;
  items: { slug: string; title: string; description?: string | undefined; position: number }[];
}

const sectionMap = new Map<string, SidebarSection>();

for (const doc of allDocs) {
  const parts = doc.id.split('--');
  const category = doc.data.category ?? (parts.length > 1 ? (parts[0] ?? 'General') : 'General');
  const slug = doc.id.replace(/--/g, '/');

  if (!sectionMap.has(category)) {
    sectionMap.set(category, { label: category, items: [] });
  }
  sectionMap.get(category)?.items.push({
    slug,
    title: doc.data.title,
    description: doc.data.description,
    position: doc.data.sidebar_position ?? 99,
  });
}

for (const section of sectionMap.values()) {
  section.items.sort((a, b) => a.position - b.position);
}

const sections = Array.from(sectionMap.values());
---

<DocLayout
  title="fail2zig · docs"
  description="Documentation for fail2zig — install, configure, migrate, and operate."
>
  <h1>Documentation</h1>
  <p class="docs-lede">Install, configure, migrate, and operate fail2zig.</p>

  <div class="docs-index-groups">
    {
      sections.map((section) => (
        <section class="index-section">
          <h2>{section.label}</h2>
          <ul class="index-list">
            {section.items.map((item) => (
              <li>
                <a href={`/docs/${item.slug}`}>
                  <span class="doc-title">{item.title}</span>
                  {item.description && <span class="doc-desc">{item.description}</span>}
                </a>
              </li>
            ))}
          </ul>
        </section>
      ))
    }
  </div>
</DocLayout>

<style>
  .docs-lede {
    color: var(--fg-body);
    font-size: 16px;
    max-width: 68ch;
    margin: 0 0 40px;
  }
  .docs-index-groups {
    display: grid;
    gap: 48px;
  }
  .index-section h2 {
    font-family: var(--mono);
    font-size: 12px !important;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--fg);
    font-weight: 600;
    margin: 0 0 16px !important;
    padding: 0 !important;
    border-top: none !important;
    display: inline-flex;
    align-items: center;
    gap: 10px;
  }
  .index-section h2::before {
    content: '';
    display: inline-block;
    width: 6px;
    height: 6px;
    background: var(--accent);
    transform: translateY(-1px);
  }
  .index-list {
    list-style: none;
    padding: 0 !important;
    margin: 0;
    max-width: none !important;
    border-top: 1px solid var(--line-hairline);
  }
  .index-list li {
    border-bottom: 1px solid var(--line-hairline);
    margin: 0 !important;
  }
  .index-list a {
    display: grid;
    grid-template-columns: minmax(0, 240px) 1fr;
    gap: 24px;
    padding: 14px 0;
    color: inherit;
    transition: color 0.12s, background 0.12s;
  }
  .index-list a:hover {
    background: linear-gradient(90deg, var(--bg-elev) 0%, transparent 70%);
  }
  .index-list a:hover .doc-title {
    color: var(--accent);
  }
  .doc-title {
    font-family: var(--mono);
    font-size: 14px;
    font-weight: 400;
    color: var(--fg);
    transition: color 0.12s;
  }
  .doc-desc {
    font-size: 13px;
    color: var(--fg-body);
    line-height: 1.55;
  }

  @media (max-width: 720px) {
    .index-list a {
      grid-template-columns: 1fr;
      gap: 4px;
    }
  }
</style>
