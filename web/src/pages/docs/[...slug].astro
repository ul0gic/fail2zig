---
import type { CollectionEntry } from 'astro:content';
import { getCollection, render } from 'astro:content';
import DocLayout from '@/layouts/DocLayout.astro';

type DocEntry = CollectionEntry<'docs'>;

interface StaticPath {
  params: { slug: string };
  props: { entry: DocEntry };
}

export async function getStaticPaths(): Promise<StaticPath[]> {
  const docs = await getCollection('docs');
  return docs.map((entry) => ({
    params: { slug: entry.id.replace(/--/g, '/') },
    props: { entry },
  }));
}

interface Props {
  entry: DocEntry;
}

const { entry } = Astro.props;
const { Content, headings } = await render(entry);

const currentSlug = entry.id.replace(/--/g, '/');
const tocHeadings = headings.filter((h) => h.depth <= 3);
const category = entry.data.category ?? 'General';
const breadcrumbHtml = `<span>docs</span> / ${category} / ${entry.data.title}`;
---

<DocLayout
  title={`${entry.data.title} · fail2zig docs`}
  description={entry.data.description}
  activeSlug={currentSlug}
  breadcrumb={breadcrumbHtml}
  tocHeadings={tocHeadings}
  lastVerified={entry.data.last_verified}
>
  <Content />

  <Fragment slot="actions">
    <button class="copy-page-btn btn ghost" data-slug={currentSlug}>Copy page as markdown</button>
    <a
      href={`https://github.com/ul0gic/fail2zig/edit/main/web/src/content/docs/${currentSlug.replaceAll('/', '--')}.md`}
      class="btn ghost"
      rel="noopener noreferrer">Edit on GitHub &rarr;</a
    >
  </Fragment>
</DocLayout>

<script is:inline>
  (function () {
    function copyText(text) {
      if (navigator.clipboard && window.isSecureContext) {
        return navigator.clipboard.writeText(text);
      }
      // Fallback for non-secure contexts.
      return new Promise(function (resolve, reject) {
        try {
          var ta = document.createElement('textarea');
          ta.value = text;
          ta.style.position = 'fixed';
          ta.style.opacity = '0';
          document.body.appendChild(ta);
          ta.select();
          document.execCommand('copy');
          document.body.removeChild(ta);
          resolve();
        } catch (e) {
          reject(e);
        }
      });
    }

    function flash(btn, label) {
      var orig = btn.textContent;
      btn.textContent = label;
      setTimeout(function () {
        btn.textContent = orig;
      }, 1200);
    }

    function installCodeCopyButtons() {
      // rehype-pretty-code wraps pre in a <figure data-rehype-pretty-code-figure>.
      // Anchor the button on the wrapper when present so it doesn't scroll
      // with long lines; fall back to the bare <pre> otherwise.
      var blocks = document.querySelectorAll('.doc-content pre');
      blocks.forEach(function (pre) {
        if (pre.classList.contains('mermaid')) return;
        if (pre.querySelector('code[data-language="mermaid"]')) return;
        var anchor = pre.closest('figure[data-rehype-pretty-code-figure]') || pre;
        if (anchor.dataset.copyInstalled === '1') return;
        anchor.dataset.copyInstalled = '1';
        anchor.style.position = 'relative';

        var btn = document.createElement('button');
        btn.type = 'button';
        btn.className = 'code-copy-btn';
        btn.textContent = 'copy';
        btn.setAttribute('aria-label', 'Copy code');
        anchor.appendChild(btn);
      });
    }

    function onCopyClick(e) {
      var btn = e.target.closest('.code-copy-btn, .copy-page-btn');
      if (!btn) return;
      e.preventDefault();

      if (btn.classList.contains('copy-page-btn')) {
        var content = document.querySelector('.doc-content');
        if (!content) return;
        copyText(content.innerText).then(function () {
          flash(btn, 'Copied!');
        });
        return;
      }

      var anchor = btn.parentElement;
      if (!anchor) return;
      var code = anchor.querySelector('pre code') || anchor.querySelector('code');
      if (!code) return;
      copyText(code.textContent || '').then(function () {
        flash(btn, 'copied');
      });
    }

    function init() {
      installCodeCopyButtons();
      document.addEventListener('click', onCopyClick);
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', init);
    } else {
      init();
    }
  })();
</script>
