---
import BaseLayout from '@/layouts/BaseLayout.astro';
---

<BaseLayout
  title="fail2zig · changelog"
  description="Every release of fail2zig, in the order it shipped. Scope, behavior changes, commits, and benchmark deltas."
  activeNav="/changelog"
>
  <header class="cl-header">
    <div class="wrap">
      <div class="eyebrow" style="margin-bottom:20px"><span class="dot"></span>Changelog</div>
      <h1>
        Everything that shipped, <br />in the order it shipped.
      </h1>
      <p class="lede">
        First public release is v0.1.0 (2026-04-24). Each entry lists scope, behavior change, and
        the commit. Benchmark deltas where the change touched a hot path.
      </p>
      <div class="subline">
        <span
          >git &middot; <a
            href="https://github.com/ul0gic/fail2zig"
            style="color:var(--fg-dim)"
            rel="noopener noreferrer">github.com/ul0gic/fail2zig</a
          ></span
        >
        <span
          >release &middot; <a
            href="https://github.com/ul0gic/fail2zig/releases/tag/v0.1.0"
            style="color:var(--fg-dim)"
            rel="noopener noreferrer">v0.1.0 on GitHub</a
          ></span
        >
        <span
          >format &middot; <a
            href="https://keepachangelog.com"
            style="color:var(--fg-dim)"
            rel="noopener noreferrer">keep a changelog</a
          ></span
        >
      </div>
    </div>
  </header>

  <div class="wrap cl-body">
    <aside class="cl-side">
      <h5>Releases</h5>
      <a href="#v0-1-0" class="active">0.1.0</a>

      <div class="filter">
        <h5 style="margin-top:24px">Categories</h5>
        <span class="pill feat">feature</span>
        <span class="pill sec">security</span>
        <span class="pill perf">performance</span>
        <span class="pill fix">fix</span>
      </div>
    </aside>

    <main>
      <!-- v0.1.0 -->
      <section class="release" id="v0-1-0">
        <div class="release-head">
          <h2>0.1.0</h2>
          <span class="ver-date">2026-04-24</span>
          <span class="ver-tag current">stable</span>
          <span class="ver-sha">sha &middot; 1340cae</span>
        </div>
        <p class="release-summary">
          First public release. A single static musl binary replaces fail2ban's Python runtime,
          regex engine, and shell-out action chain. Hardened across eleven Phase-7 security issues
          and eight real-system SYS bugs before tagging. AGPL-3.0-or-later.
        </p>

        <div class="bench-delta">
          <div class="cell">
            <div class="k">Parse throughput</div>
            <div class="v">5.96M l/s</div>
            <div class="d up">271&times; target</div>
          </div>
          <div class="cell">
            <div class="k">Ban latency p99</div>
            <div class="v">932 ns</div>
            <div class="d up">p50 365 ns</div>
          </div>
          <div class="cell">
            <div class="k">Binary (musl x86_64)</div>
            <div class="v">877 KB</div>
            <div class="d">stripped</div>
          </div>
          <div class="cell">
            <div class="k">Resident memory</div>
            <div class="v">22 MB</div>
            <div class="d">64 MB ceiling</div>
          </div>
        </div>

        <div class="change-group feat">
          <h3>Features</h3>
          <ul class="change-list">
            <li>
              <span class="scope">engine</span>
              <span class="msg"
                >Single static musl binary &middot; zero runtime dependencies &middot; 877 KB
                stripped</span
              >
              <a
                href="https://github.com/ul0gic/fail2zig/commit/5a85cc2"
                class="ref"
                rel="noopener noreferrer">5a85cc2</a
              >
            </li>
            <li>
              <span class="scope">core</span>
              <span class="msg"
                >epoll / timerfd / signalfd event loop &middot; inotify log watcher with rotation +
                copytruncate handling</span
              >
              <a
                href="https://github.com/ul0gic/fail2zig/commit/98cd331"
                class="ref"
                rel="noopener noreferrer">98cd331</a
              >
            </li>
            <li>
              <span class="scope">parser</span>
              <span class="msg"
                >Comptime-specialized parsers &middot; no regex engine in the process &middot;
                zero-allocation hot path verified with <code>FailingAllocator</code></span
              >
              <a
                href="https://github.com/ul0gic/fail2zig/commit/ec31dee"
                class="ref"
                rel="noopener noreferrer">ec31dee</a
              >
            </li>
            <li>
              <span class="scope">firewall</span>
              <span class="msg"
                >Pure netlink for nftables (no libnftnl, no shell-out) &middot; argv for iptables +
                ipset</span
              >
              <a
                href="https://github.com/ul0gic/fail2zig/commit/ec31dee"
                class="ref"
                rel="noopener noreferrer">ec31dee</a
              >
            </li>
            <li>
              <span class="scope">state</span>
              <span class="msg"
                >Fixed-arena state tracker with three eviction policies &middot; atomic CRC-checked
                persistence &middot; per-IP 128-slot ring buffer</span
              >
              <a
                href="https://github.com/ul0gic/fail2zig/commit/a9e77dc"
                class="ref"
                rel="noopener noreferrer">a9e77dc</a
              >
            </li>
            <li>
              <span class="scope">config</span>
              <span class="msg"
                >Native TOML parser + full <code>--import-config /etc/fail2ban</code> pipeline &middot;
                translates filter.d regexes &middot; maps action.d backends &middot; emits validated TOML</span
              >
              <a
                href="https://github.com/ul0gic/fail2zig/commit/3af15fd"
                class="ref"
                rel="noopener noreferrer">3af15fd</a
              >
            </li>
            <li>
              <span class="scope">filters</span>
              <span class="msg"
                >15 built-in comptime filters: sshd, nginx-*, apache-*, postfix / dovecot / courier,
                named, vsftpd, proftpd, mysqld, recidive</span
              >
              <a
                href="https://github.com/ul0gic/fail2zig/commit/3af15fd"
                class="ref"
                rel="noopener noreferrer">3af15fd</a
              >
            </li>
            <li>
              <span class="scope">cli</span>
              <span class="msg"
                ><code>fail2zig-client</code> &mdash; status / ban / unban / list / jails / reload &middot;
                table, JSON, plain output &middot; bash / zsh / fish completions</span
              >
              <a
                href="https://github.com/ul0gic/fail2zig/commit/2130f37"
                class="ref"
                rel="noopener noreferrer">2130f37</a
              >
            </li>
            <li>
              <span class="scope">metrics</span>
              <span class="msg"
                >Built-in HTTP/1.1 server &middot; <code>/metrics</code> (Prometheus), <code
                  >/api/bans</code
                > (JSON), <code>/events</code> (WebSocket, RFC 6455)</span
              >
              <a
                href="https://github.com/ul0gic/fail2zig/commit/2130f37"
                class="ref"
                rel="noopener noreferrer">2130f37</a
              >
            </li>
            <li>
              <span class="scope">demo</span>
              <span class="msg"
                >Live internet-exposed honeypot at <a href="/demo">fail2zig.com/demo</a> &middot; real
                sshd + nginx attack surface &middot; three-pane dashboard</span
              >
              <a
                href="https://github.com/ul0gic/fail2zig/commit/1803321"
                class="ref"
                rel="noopener noreferrer">1803321</a
              >
            </li>
            <li>
              <span class="scope">release</span>
              <span class="msg"
                >Static musl binaries for x86_64 + aarch64 &middot; SHA256SUMS &middot; hardened
                systemd unit &middot; <code>scripts/install.sh</code> one-shot installer</span
              >
              <a
                href="https://github.com/ul0gic/fail2zig/commit/1340cae"
                class="ref"
                rel="noopener noreferrer">1340cae</a
              >
            </li>
          </ul>
        </div>

        <div class="change-group sec">
          <h3>Security</h3>
          <ul class="change-list">
            <li>
              <span class="scope">parser</span>
              <span class="msg"
                >SEC-001 (HIGH) &mdash; IPv4-mapped IPv6 canonicalization closes ban-evasion by
                peer-format flipping</span
              >
              <a
                href="https://github.com/ul0gic/fail2zig/commit/8bfc74f"
                class="ref"
                rel="noopener noreferrer">8bfc74f</a
              >
            </li>
            <li>
              <span class="scope">ipc</span>
              <span class="msg"
                >SEC-002 (MEDIUM) &mdash; <code>umask(0o117)</code> around <code>bind()</code> closes
                the socket-permissions race window</span
              >
              <a
                href="https://github.com/ul0gic/fail2zig/commit/8bfc74f"
                class="ref"
                rel="noopener noreferrer">8bfc74f</a
              >
            </li>
            <li>
              <span class="scope">http</span>
              <span class="msg"
                >SEC-005 / SEC-008 &mdash; security headers on every response &middot; 5s per-client
                read deadline &middot; 100/sec accept rate cap</span
              >
              <a
                href="https://github.com/ul0gic/fail2zig/commit/8bfc74f"
                class="ref"
                rel="noopener noreferrer">8bfc74f</a
              >
            </li>
            <li>
              <span class="scope">fuzz</span>
              <span class="msg"
                >Fuzz corpora for parser &middot; IP parser &middot; IPC protocol &middot; TOML
                config &mdash; all with <code>FailingAllocator</code> to surface unbounded allocation
                as <code>OutOfMemory</code></span
              >
              <a
                href="https://github.com/ul0gic/fail2zig/commit/8bfc74f"
                class="ref"
                rel="noopener noreferrer">8bfc74f</a
              >
            </li>
            <li>
              <span class="scope">systemd</span>
              <span class="msg"
                >Hardened unit: <code>CAP_NET_ADMIN + CAP_DAC_READ_SEARCH</code> only &middot; <code
                  >ProtectSystem=strict</code
                > &middot; <code>NoNewPrivileges</code> &middot; seccomp filter &middot; <code
                  >systemd-analyze security</code
                > 2.4</span
              >
              <a
                href="https://github.com/ul0gic/fail2zig/commit/7df630f"
                class="ref"
                rel="noopener noreferrer">7df630f</a
              >
            </li>
            <li>
              <span class="scope">license</span>
              <span class="msg"
                >AGPL-3.0-or-later &middot; trademark asserted on "fail2zig" name + logo &middot;
                vulnerabilities reported via GitHub Private Security Advisories</span
              >
              <a
                href="https://github.com/ul0gic/fail2zig/commit/ef16d7c"
                class="ref"
                rel="noopener noreferrer">ef16d7c</a
              >
            </li>
          </ul>
        </div>

        <div class="change-group perf">
          <h3>Performance</h3>
          <ul class="change-list">
            <li>
              <span class="scope">bench</span>
              <span class="msg"
                >Parse throughput <strong>5.96M lines/sec</strong> (271&times; the 22K target) &middot;
                ban latency p50 365 ns / p99 932 ns (1000&times; under the 1ms target)</span
              >
              <a
                href="https://github.com/ul0gic/fail2zig/commit/8bfc74f"
                class="ref"
                rel="noopener noreferrer">8bfc74f</a
              >
            </li>
            <li>
              <span class="scope">memory</span>
              <span class="msg"
                >Hard memory ceiling held across 50K unique IPs: 21,845 entries resident, 15,606
                evictions &mdash; ceiling never exceeded</span
              >
              <a
                href="https://github.com/ul0gic/fail2zig/commit/8bfc74f"
                class="ref"
                rel="noopener noreferrer">8bfc74f</a
              >
            </li>
            <li>
              <span class="scope">binary</span>
              <span class="msg"
                >Static musl binary <strong>877 KB</strong> (x86_64) / <strong>801 KB</strong> (aarch64)
                &mdash; well under the 5 MB ceiling</span
              >
              <a
                href="https://github.com/ul0gic/fail2zig/commit/1340cae"
                class="ref"
                rel="noopener noreferrer">1340cae</a
              >
            </li>
          </ul>
        </div>

        <div class="change-group fix">
          <h3>Fixes</h3>
          <ul class="change-list">
            <li>
              <span class="scope">ws</span>
              <span class="msg"
                >SYS-010 (CRITICAL) &mdash; use-after-free in <code>ws.dispatchFrame</code> on close /
                binary frames</span
              >
              <a
                href="https://github.com/ul0gic/fail2zig/commit/b101619"
                class="ref"
                rel="noopener noreferrer">b101619</a
              >
            </li>
            <li>
              <span class="scope">filter</span>
              <span class="msg"
                >SYS-011 (HIGH) &mdash; sshd filter matched clean disconnects, causing operator
                self-ban during honeypot bring-up</span
              >
              <a
                href="https://github.com/ul0gic/fail2zig/commit/b101619"
                class="ref"
                rel="noopener noreferrer">b101619</a
              >
            </li>
            <li>
              <span class="scope">state</span>
              <span class="msg"
                >SYS-007 (HIGH) &mdash; restored bans on restart now re-installed into the firewall;
                previously the state tracker held them but the kernel didn't enforce</span
              >
              <a
                href="https://github.com/ul0gic/fail2zig/commit/dc916a9"
                class="ref"
                rel="noopener noreferrer">dc916a9</a
              >
            </li>
            <li>
              <span class="scope">state</span>
              <span class="msg"
                >SYS-008 (HIGH) &mdash; <code>bantime_increment</code> now wired from <code
                  >[defaults]</code
                > to the state tracker (was silently ignored)</span
              >
              <a
                href="https://github.com/ul0gic/fail2zig/commit/3d866c7"
                class="ref"
                rel="noopener noreferrer">3d866c7</a
              >
            </li>
            <li>
              <span class="scope">ws</span>
              <span class="msg"
                >Broadcast wiring + event schema aligned to the documented <code
                  >type / ts / payload</code
                > envelope; dashboard counters now tick in real time</span
              >
              <a
                href="https://github.com/ul0gic/fail2zig/commit/4d75186"
                class="ref"
                rel="noopener noreferrer">4d75186</a
              >
            </li>
            <li>
              <span class="scope">ipc</span>
              <span class="msg"
                >ISSUE-003 &mdash; daemon and client socket-path defaults unified on <code
                  >/run/fail2zig/fail2zig.sock</code
                ></span
              >
              <a
                href="https://github.com/ul0gic/fail2zig/commit/2130f37"
                class="ref"
                rel="noopener noreferrer">2130f37</a
              >
            </li>
            <li>
              <span class="scope">build</span>
              <span class="msg"
                >ISSUE-004 &mdash; <code>@bitCast</code> size mismatch (i128 &rarr; u64) resolved via
                <code>@truncate</code></span
              >
              <a
                href="https://github.com/ul0gic/fail2zig/commit/2130f37"
                class="ref"
                rel="noopener noreferrer">2130f37</a
              >
            </li>
          </ul>
        </div>
      </section>
    </main>
  </div>
</BaseLayout>

<style>
  .cl-header {
    padding: 64px 0 48px;
    border-bottom: 1px solid var(--line-soft);
  }
  .cl-header h1 {
    font-size: clamp(40px, 5vw, 64px);
    margin-bottom: 20px;
  }
  .cl-header .lede {
    font-size: 19px;
    max-width: 60ch;
  }
  .cl-header .subline {
    display: flex;
    gap: 24px;
    margin-top: 28px;
    font-family: var(--mono);
    font-size: 12px;
    color: var(--fg-mute);
    flex-wrap: wrap;
  }

  .cl-body {
    display: grid;
    grid-template-columns: 220px 1fr;
    gap: 64px;
    padding: 64px 0;
  }
  .cl-side {
    font-family: var(--mono);
    font-size: 12px;
    position: sticky;
    top: 80px;
    align-self: start;
  }
  .cl-side h5 {
    font-size: 11px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--fg-mute);
    margin: 0 0 12px;
    font-weight: 500;
  }
  .cl-side a {
    display: block;
    padding: 5px 0;
    color: var(--fg-dim);
    border-left: 2px solid transparent;
    padding-left: 10px;
    margin-left: -10px;
  }
  .cl-side a:hover {
    color: var(--fg);
  }
  .cl-side a.active {
    color: var(--accent);
    border-left-color: var(--accent);
  }
  .cl-side .filter {
    display: flex;
    flex-direction: column;
    gap: 4px;
    margin-top: 24px;
  }
  .cl-side .pill {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 4px 8px;
    border: 1px solid var(--line);
    color: var(--fg-dim);
    font-size: 11px;
  }
  .cl-side .pill::before {
    content: '';
    width: 6px;
    height: 6px;
  }
  .cl-side .pill.feat::before {
    background: var(--accent);
  }
  .cl-side .pill.sec::before {
    background: var(--danger);
  }
  .cl-side .pill.perf::before {
    background: var(--safe);
  }
  .cl-side .pill.fix::before {
    background: var(--fg-mute);
  }

  .release {
    padding-bottom: 64px;
    margin-bottom: 64px;
    border-bottom: 1px solid var(--line-soft);
  }
  .release:last-child {
    border-bottom: none;
  }
  .release-head {
    display: flex;
    align-items: baseline;
    gap: 20px;
    margin-bottom: 24px;
    padding-bottom: 16px;
    border-bottom: 1px dashed var(--line-soft);
  }
  .release-head h2 {
    font-family: var(--mono);
    font-size: 24px;
    font-weight: 500;
    letter-spacing: -0.01em;
  }
  .release-head .ver-date {
    color: var(--fg-mute);
    font-family: var(--mono);
    font-size: 13px;
  }
  .release-head .ver-tag {
    font-family: var(--mono);
    font-size: 11px;
    padding: 3px 8px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    border: 1px solid var(--line);
    color: var(--fg-dim);
  }
  .release-head .ver-tag.current {
    color: var(--accent);
    border-color: var(--accent-dim);
  }
  .release-head .ver-sha {
    margin-left: auto;
    color: var(--fg-mute);
    font-family: var(--mono);
    font-size: 12px;
  }

  .release-summary {
    color: var(--fg-dim);
    font-size: 15px;
    max-width: 70ch;
    margin-bottom: 28px;
  }

  .change-group {
    margin-bottom: 28px;
  }
  .change-group h3 {
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--fg-mute);
    font-weight: 500;
    margin-bottom: 12px;
    display: flex;
    align-items: center;
    gap: 10px;
  }
  .change-group h3::before {
    content: '';
    display: inline-block;
    width: 8px;
    height: 8px;
  }
  .change-group.feat h3::before {
    background: var(--accent);
  }
  .change-group.sec h3::before {
    background: var(--danger);
  }
  .change-group.perf h3::before {
    background: var(--safe);
  }
  .change-group.fix h3::before {
    background: var(--fg-mute);
  }
  .change-group.break h3::before {
    background: var(--danger);
  }

  .change-list {
    margin: 0;
    padding: 0;
    list-style: none;
  }
  .change-list li {
    padding: 12px 0;
    border-top: 1px solid var(--line-soft);
    display: grid;
    grid-template-columns: 80px 1fr auto;
    gap: 20px;
    align-items: baseline;
    font-size: 14px;
  }
  .change-list li:last-child {
    border-bottom: 1px solid var(--line-soft);
  }
  .change-list .scope {
    font-family: var(--mono);
    font-size: 11px;
    color: var(--accent);
    letter-spacing: 0.06em;
  }
  .change-list .msg {
    color: var(--fg);
  }
  .change-list .msg .detail {
    color: var(--fg-dim);
    font-size: 13px;
    margin-top: 3px;
    display: block;
  }
  .change-list .ref {
    font-family: var(--mono);
    font-size: 11px;
    color: var(--fg-mute);
  }
  .change-list .ref:hover {
    color: var(--accent);
  }

  .bench-delta {
    background: var(--bg-elev);
    border: 1px solid var(--line-soft);
    padding: 20px 24px;
    margin: 16px 0 24px;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 24px;
  }
  .bench-delta .cell .k {
    font-family: var(--mono);
    font-size: 10px;
    color: var(--fg-mute);
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }
  .bench-delta .cell .v {
    font-family: var(--mono);
    font-size: 18px;
    color: var(--fg);
    font-weight: 500;
    margin-top: 4px;
    letter-spacing: -0.01em;
  }
  .bench-delta .cell .d {
    font-family: var(--mono);
    font-size: 11px;
    margin-top: 2px;
  }
  .bench-delta .cell .d.up {
    color: var(--safe);
  }
  .bench-delta .cell .d.down {
    color: var(--danger);
  }

  @media (max-width: 800px) {
    .cl-body {
      grid-template-columns: 1fr;
      gap: 32px;
      padding: 32px 0;
    }
    .cl-side {
      position: static;
    }
    .change-list li {
      grid-template-columns: 1fr;
      gap: 4px;
    }
    .bench-delta {
      grid-template-columns: 1fr 1fr;
    }
  }
</style>
