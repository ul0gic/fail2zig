---
import BaseLayout from '@/layouts/BaseLayout.astro';
import PipelineDiagram from '@/components/PipelineDiagram.astro';

const adds: readonly { title: string; body: string; meta: string }[] = [
  {
    title: 'Smaller attack surface',
    body: '~12K lines of Zig versus ~45K lines of Python + CPython runtime + stdlib + C extensions. A smaller trusted computing base means fewer places for bugs to hide.',
    meta: '<span class="hl">~12K LOC</span> · no interpreter · no VM',
  },
  {
    title: 'Bounded memory',
    body: 'A hard, configurable ceiling the daemon never exceeds — regardless of attack volume. Eviction policy is operator-defined. No garbage collector in the loop.',
    meta: 'hard ceiling · <span class="hl">configurable</span> · eviction policy',
  },
  {
    title: 'Higher throughput',
    body: 'Comptime-generated parsers with SIMD acceleration. Measured at 5.96M lines/sec — keeping pace with busy SSH, postfix, and nginx log streams.',
    meta: '5.96M l/s measured · SIMD · <span class="hl">zero-alloc hot path</span>',
  },
  {
    title: 'Instant readiness',
    body: 'No interpreter startup, no import chain. The daemon is accepting log events within milliseconds of exec. After a reboot, the gap where nothing is banning is as short as the kernel allows.',
    meta: 'no import cost · <span class="hl">no rule-compile cost</span>',
  },
  {
    title: 'Runs anywhere',
    body: 'Static musl binary. Works on distroless containers, scratch images, hardened minimal servers, embedded Linux, OpenWrt routers — anywhere a Python runtime is unacceptable.',
    meta: 'musl · <span class="hl">4 architectures</span> · no runtime',
  },
  {
    title: 'Clean config',
    body: 'Native TOML with strict validation — unknown keys are errors, not silent no-ops. --import-config migrates your existing fail2ban tree, translating jails and filters automatically.',
    meta: '<span class="hl">validated</span> · documented · import path',
  },
];
---

<BaseLayout title="fail2zig — intrusion prevention, rebuilt" activeNav="/">
  <header class="hero">
    <div class="wrap">
      <div class="hero-grid">
        <div>
          <h1>
            Single binary.<br />
            <span class="accent">Zero dependencies.</span><br />
            Real intrusion prevention.
          </h1>
          <p class="hero-lede">
            Predictable behavior under hostile input.
          </p>
          <div class="hero-cta">
            <a href="/install" class="btn primary">$ Install fail2zig &nbsp;&rarr;</a>
            <a href="/threat-model" class="btn ghost">Read the threat model</a>
          </div>
          <div class="hero-metrics">
            <div class="hero-metric">
              <div class="n">5.96M</div>
              <div class="l">lines/sec parsed</div>
            </div>
            <div class="hero-metric">
              <div class="n">932ns</div>
              <div class="l">ban decision p99</div>
            </div>
            <div class="hero-metric">
              <div class="n">877KB</div>
              <div class="l">static binary</div>
            </div>
            <div class="hero-metric">
              <div class="n">0</div>
              <div class="l">runtime deps</div>
            </div>
          </div>
        </div>

        <PipelineDiagram />
      </div>
    </div>
  </header>

  <!-- WHY IT'S DIFFERENT -->
  <section class="section">
    <div class="wrap">
      <div class="section-head">
        <div class="eyebrow"><span class="dot"></span>01 &middot; Why it&rsquo;s different</div>
        <div>
          <h2>Less runtime. Smaller TCB. Same job.</h2>
          <p class="lede mt-4">
            fail2zig keeps the operational model familiar while cutting runtime bulk, bounding
            memory use, and moving parsing into a smaller, more explicit execution path.
          </p>
        </div>
      </div>

      <div class="adds-matrix mt-10">
        {
          adds.map((item, i) => (
            <div class="adds-cell">
              <div class="adds-index"><span class="mark">§</span> {String(i + 1).padStart(2, '0')}</div>
              <h3 class="adds-title">{item.title}</h3>
              <p class="adds-body">{item.body}</p>
              <div class="adds-meta" set:html={item.meta}></div>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- BENCHMARKS -->
  <section class="section section--band" id="benchmarks">
    <div class="wrap">
      <div class="section-head">
        <div class="eyebrow"><span class="dot"></span>02 &middot; Benchmarks</div>
        <div>
          <h2>Measured, not marketing.</h2>
          <p class="lede" style="margin-top:16px">
            Every figure measured on real hardware under real load. Not synthetic, not modeled.
            The benchmark suite ships with the source and is fully reproducible.
          </p>
        </div>
      </div>

      <div class="bench-wrap">
        <div class="bench-chart">
          <h4>Parse throughput &middot; auth.log</h4>
          <div class="bench-bar-row">
            <span class="bench-label">fail2ban</span>
            <div class="bench-bar">
              <div class="fill dim" data-w="0.007" style="width: 0.007%;"></div>
            </div>
            <span class="bench-val">~420 l/s</span>
          </div>
          <div class="bench-bar-row">
            <span class="bench-label">SSHGuard</span>
            <div class="bench-bar">
              <div class="fill dim" data-w="0.05" style="width: 0.05%;"></div>
            </div>
            <span class="bench-val">~3.1k l/s</span>
          </div>
          <div class="bench-bar-row">
            <span class="bench-label">CrowdSec</span>
            <div class="bench-bar">
              <div class="fill dim" data-w="0.08" style="width: 0.08%;"></div>
            </div>
            <span class="bench-val">~4.9k l/s</span>
          </div>
          <div class="bench-bar-row">
            <span class="bench-label">fail2zig</span>
            <div class="bench-bar">
              <div class="fill accent" data-w="100" style="width: 100%;"></div>
            </div>
            <span class="bench-val accent">5.96M l/s</span>
          </div>
          <div class="bench-note">
            Measured with a <code>ReleaseSafe</code> build,
            <code>tests/benchmark/parse_throughput.zig</code>. Bars scale linearly. Reproduction
            guide in <a href="/docs" style="color:var(--accent)">tests/benchmark/README.md</a>.
          </div>
        </div>

        <div class="bench-chart">
          <h4>Memory under attack &middot; 50K unique IPs &middot; sustained</h4>
          <div class="bench-bar-row">
            <span class="bench-label">fail2ban</span>
            <div class="bench-bar">
              <div class="fill dim" data-w="88" style="width: 88%;"></div>
            </div>
            <span class="bench-val">~740 MB</span>
          </div>
          <div class="bench-bar-row">
            <span class="bench-label">CrowdSec</span>
            <div class="bench-bar">
              <div class="fill dim" data-w="32" style="width: 32%;"></div>
            </div>
            <span class="bench-val">~210 MB</span>
          </div>
          <div class="bench-bar-row">
            <span class="bench-label">SSHGuard</span>
            <div class="bench-bar">
              <div class="fill dim" data-w="10" style="width: 10%;"></div>
            </div>
            <span class="bench-val">~58 MB</span>
          </div>
          <div class="bench-bar-row">
            <span class="bench-label">fail2zig</span>
            <div class="bench-bar">
              <div class="fill accent" data-w="9" style="width: 9%;"></div>
            </div>
            <span class="bench-val accent">&le;64 MB</span>
          </div>
          <div class="bench-note">
            Hard ceiling, configurable. Under a 50K unique-IP attack: 21,845 resident entries +
            15,606 evicted. The daemon never exceeded the cap. Eviction policy is operator-defined.
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ARCHITECTURE / FEATURES -->
  <section class="section" id="architecture">
    <div class="wrap">
      <div class="section-head">
        <div class="eyebrow"><span class="dot"></span>03 &middot; Architecture</div>
        <div>
          <h2>Six components. One binary. Every allocation accounted for.</h2>
          <p class="lede" style="margin-top:16px">
            A straight pipeline: log in, ban out. Explicit allocator boundaries at every stage. No
            hidden work, no implicit runtime, no third-party code in the critical path.
          </p>
        </div>
      </div>

      <div class="feature-grid">
        <div class="feature">
          <div class="idx">01 / LOG WATCHER</div>
          <h3>Event-driven, rotation-aware</h3>
          <p>
            inotify on Linux, kqueue on BSD, sd_journal for systemd, io_uring for high-throughput
            batched I/O on 5.1+. Handles rename, truncate, and new-file creation without missing
            events.
          </p>
          <div class="meta">linux &middot; bsd &middot; journald &middot; stdin</div>
        </div>
        <div class="feature">
          <div class="idx">02 / PARSER ENGINE</div>
          <h3>Comptime filters, zero-copy</h3>
          <p>
            Built-in filters compile to specialised parsers at build time &mdash; no runtime regex
            engine in process. SIMD-accelerated IP extraction and timestamp parsing where the CPU
            supports it.
          </p>
          <div class="meta">no pcre &middot; no allocations/line &middot; simd</div>
        </div>
        <div class="feature">
          <div class="idx">03 / STATE TRACKER</div>
          <h3>Fixed-size arena, hard ceiling</h3>
          <p>
            Pre-allocated buckets, no dynamic resizing under load, configurable max with explicit
            eviction policy. Memory usage has a hard cap regardless of attack volume.
          </p>
          <div class="meta">evict-oldest &middot; ban-all &middot; drop-unbanned</div>
        </div>
        <div class="feature">
          <div class="idx">04 / BAN EXECUTOR</div>
          <h3>Pluggable firewall backends</h3>
          <p>
            nftables, iptables, ipset on day one. eBPF/XDP in Phase 2 &mdash; drops packets at the
            NIC driver level before they reach the kernel TCP stack. pf for BSD.
          </p>
          <div class="meta">nftables &middot; ipset &middot; xdp &middot; pf</div>
        </div>
        <div class="feature">
          <div class="idx">05 / CONFIG</div>
          <h3>Native + fail2ban-compatible</h3>
          <p>
            Native fail2zig.toml for new deployments. A dedicated parser reads jail.conf,
            jail.local, filter.d, action.d. The <code style="color:var(--accent)"
              >--import-config</code
            > flag converts your existing fail2ban tree.
          </p>
          <div class="meta">validated &middot; documented &middot; hot-reload (ph.2)</div>
        </div>
        <div class="feature">
          <div class="idx">06 / METRICS</div>
          <h3>Prometheus, out of the box</h3>
          <p>
            Built-in HTTP metrics endpoint &mdash; bind-restricted, read-only. Ban rate, parse
            throughput, active bans, per-jail stats. Structured JSON logs; syslog optional.
          </p>
          <div class="meta">/metrics &middot; structured &middot; signed-audit</div>
        </div>
      </div>
    </div>
  </section>

  <!-- COMPARISON -->
  <section class="section">
    <div class="wrap">
      <div class="section-head">
        <div class="eyebrow"><span class="dot"></span>04 &middot; Landscape</div>
        <div>
          <h2>How it compares.</h2>
          <p class="lede" style="margin-top:16px">
            Same category, different tradeoffs. fail2zig ships as a static binary, stays
            local-first, and avoids cloud dependency in the critical path.
          </p>
        </div>
      </div>

      <div class="cmp-wrap">
        <table class="cmp-table">
          <thead>
            <tr>
              <th class="cmp-leader">&nbsp;</th>
              <th>Language</th>
              <th>Deployment</th>
              <th>Banning</th>
              <th class="cmp-num">Throughput</th>
              <th class="cmp-num">Footprint</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td class="cmp-leader">fail2ban</td>
              <td>Python 3</td>
              <td>pkg + runtime</td>
              <td>iptables / nftables</td>
              <td class="cmp-num">~hundreds l/s</td>
              <td class="cmp-num">GC &middot; unbounded</td>
            </tr>
            <tr>
              <td class="cmp-leader">SSHGuard</td>
              <td>C</td>
              <td>single binary</td>
              <td>pf / iptables / nftables</td>
              <td class="cmp-num">medium</td>
              <td class="cmp-num">small, SSH-focused</td>
            </tr>
            <tr>
              <td class="cmp-leader">CrowdSec</td>
              <td>Go</td>
              <td>binary + cloud API</td>
              <td>iptables / nftables</td>
              <td class="cmp-num">medium-high</td>
              <td class="cmp-num">heavy &middot; cloud dep</td>
            </tr>
            <tr class="cmp-row-us">
              <td class="cmp-leader">fail2zig</td>
              <td>Zig</td>
              <td>static binary, musl</td>
              <td>nft &middot; ipset &middot; eBPF/XDP &middot; pf</td>
              <td class="cmp-num cmp-strong">5.96M l/s (measured)</td>
              <td class="cmp-num cmp-strong">fixed ceiling &middot; 0 deps</td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- INSTALL -->
  <section class="section section--band" id="install">
    <div class="wrap">
      <div class="section-head">
        <div class="eyebrow"><span class="dot"></span>05 &middot; Install</div>
        <div>
          <h2>Drop-in migration, two commands.</h2>
          <p class="lede" style="margin-top:16px">
            Fetch the binary, import the existing config, swap the service. That is the migration
            path.
          </p>
        </div>
      </div>

      <div class="install-grid">
        <div class="install-block">
          <div class="install-head">
            <span>terminal &middot; linux/x86_64</span>
            <button
              class="copy-btn"
              data-copy="curl -fsSL https://fail2zig.com/install.sh | sh
fail2zig --import-config /etc/fail2ban/"
              >copy</button
            >
          </div>
          <div class="install-body">
            <span class="cmt"># 1. fetch the static binary (877 KB, musl-linked)</span><br />
            <span class="prompt">$</span> curl -fsSL https://fail2zig.com/install.sh | sh<br />
            <br />
            <span class="cmt"># 2. migrate from fail2ban, review the generated config</span><br />
            <span class="prompt">$</span> fail2zig --import-config /etc/fail2ban/<br />
            <span style="color:var(--fg-dim)"
              >&rarr; translated 14 jails &middot; 2 warnings &middot; wrote /etc/fail2zig.toml</span
            ><br />
            <br />
            <span class="cmt"># 3. swap the service</span><br />
            <span class="prompt">$</span> systemctl disable --now fail2ban<br />
            <span class="prompt">$</span> systemctl enable --now fail2zig<br />
          </div>
        </div>

        <div class="install-block">
          <div class="install-head">
            <span>targets &middot; stripped &middot; static</span>
            <span style="color:var(--fg-dim)">via github releases</span>
          </div>
          <div class="install-body" style="font-size:12px;line-height:2">
            <div style="display:grid;grid-template-columns:1fr 1fr;gap:4px 24px">
              <div><span style="color:var(--accent)">&bull;</span> x86_64-linux-musl</div>
              <div style="color:var(--fg-dim)">877 KB</div>
              <div><span style="color:var(--accent)">&bull;</span> aarch64-linux-musl</div>
              <div style="color:var(--fg-dim)">stripped</div>
              <div><span style="color:var(--accent)">&bull;</span> armv7-linux-musleabihf</div>
              <div style="color:var(--fg-dim)">stripped</div>
              <div><span style="color:var(--accent)">&bull;</span> mips-linux-musl</div>
              <div style="color:var(--fg-dim)">stripped</div>
              <div style="color:var(--fg-dim)"><span>&cir;</span> x86_64-freebsd</div>
              <div style="color:var(--fg-dim)">planned</div>
              <div style="color:var(--fg-dim)"><span>&cir;</span> aarch64-openbsd</div>
              <div style="color:var(--fg-dim)">planned</div>
            </div>
            <div
              style="margin-top:20px;padding-top:16px;border-top:1px dashed var(--line);color:var(--fg-body);font-size:11px"
            >
              reproducible builds &middot; checksums signed with cosign &middot; minisign key
              in-repo
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="section">
    <div class="wrap">
      <div class="section-head">
        <div class="eyebrow"><span class="dot"></span>06 &middot; FAQ</div>
        <div>
          <h2>Reasonable skepticism, addressed.</h2>
        </div>
      </div>

      <div>
        <div class="faq-item">
          <div class="q-num">Q.01</div>
          <div>
            <h3>Why Zig? Why not Rust?</h3>
            <p>
              Zig gives us explicit allocator control end-to-end, comptime code generation for
              built-in filters, trivial cross-compilation to musl targets, and a language small
              enough to audit. Rust would work. Zig fits the problem.
            </p>
          </div>
        </div>
        <div class="faq-item">
          <div class="q-num">Q.02</div>
          <div>
            <h3>Is this really a drop-in replacement?</h3>
            <p>
              Phase 1 targets jail.conf + filter.d compatibility for the top 20 fail2ban filters
              (95%+ of installations). Custom Python filter code and sendmail actions are explicitly
              out of scope &mdash; they need to be rewritten or replaced.
            </p>
          </div>
        </div>
        <div class="faq-item">
          <div class="q-num">Q.03</div>
          <div>
            <h3>Can attacker-controlled log lines crash or OOM the daemon?</h3>
            <p>
              That's the threat model we designed to. Bounds-checked parsing with strict line length
              limits, no regex engine in process, fixed-size arena allocator with a hard ceiling,
              fuzz-tested parsers. <a href="/threat-model" style="color:var(--accent)"
                >Full write-up &rarr;</a
              >
            </p>
          </div>
        </div>
        <div class="faq-item">
          <div class="q-num">Q.04</div>
          <div>
            <h3>What about distroless / scratch containers?</h3>
            <p>
              First-class target. The binary is static, musl-linked, and has zero runtime
              dependencies. Drop it into a scratch image, give it CAP_NET_ADMIN, done.
            </p>
          </div>
        </div>
        <div class="faq-item">
          <div class="q-num">Q.05</div>
          <div>
            <h3>Is this a SIEM or a WAF?</h3>
            <p>
              Neither. It reads logs, acts on them, and gets out of the way. It does not
              aggregate, correlate, or inspect HTTP bodies.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section section--band" style="padding:128px 0">
    <div class="wrap" style="text-align:center">
      <h2 style="font-size:clamp(32px, 4vw, 52px);max-width:22ch;margin:0 auto 24px">
        Read the code before it reads your logs.
      </h2>
      <p class="lede" style="margin:0 auto 36px">
        Small enough to audit. Fast enough to build. Simple enough to ship.
      </p>
      <div style="display:inline-flex;gap:10px">
        <a href="https://github.com/ul0gic/fail2zig" class="btn primary" rel="noopener noreferrer"
          ><span style="color:var(--accent)">&#9733;</span> Star on GitHub &nbsp;&rarr;</a
        >
        <a href="/docs" class="btn">Read the docs</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* ---------- HERO ---------- */
  .hero {
    padding: 48px 0 0;
    border-bottom: 1px solid var(--line-soft);
    position: relative;
    overflow: hidden;
  }
  .hero .wrap {
    max-width: 1720px;
  }
  .hero-grid {
    display: grid;
    grid-template-columns: 720px minmax(0, 1fr);
    gap: 56px;
    padding: 56px 0 96px;
    align-items: start;
  }
  .hero h1 {
    font-size: clamp(36px, 3.8vw, 54px);
    line-height: 1.08;
    letter-spacing: -0.025em;
    margin-bottom: 28px;
  }
  .hero h1 .accent {
    color: var(--accent);
  }
  .hero-lede {
    font-size: 19px;
    color: var(--fg-dim);
    max-width: 56ch;
    margin: 0 0 36px;
    text-wrap: pretty;
  }
  .hero-cta {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
    margin-bottom: 40px;
  }
  .hero-metrics {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    border-top: 1px solid var(--line-soft);
    padding-top: 24px;
    gap: 24px;
  }
  .hero-metric .n {
    font-family: var(--mono);
    font-size: 22px;
    font-weight: 500;
    color: var(--fg);
    letter-spacing: -0.02em;
  }
  .hero-metric .l {
    font-family: var(--mono);
    font-size: 11px;
    color: var(--fg-mute);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-top: 4px;
  }

  /* ---------- WHAT WE ADD (spec matrix, not cards) ---------- */
  .adds-matrix {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1px;
    background: var(--line);
    border: 1px solid var(--line-strong);
  }
  @media (max-width: 960px) {
    .adds-matrix { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 640px) {
    .adds-matrix { grid-template-columns: 1fr; }
  }
  .adds-cell {
    background: var(--bg);
    padding: 36px 32px;
    display: flex;
    flex-direction: column;
    gap: 10px;
    position: relative;
  }
  /* Subtle top-edge accent on the first row only (first 3 cells in a 3-col grid). */
  .adds-cell:nth-child(-n + 3)::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 2px;
    background: var(--accent);
  }
  .adds-index {
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--fg-dim);
  }
  .adds-index .mark {
    color: var(--accent);
  }
  .adds-title {
    font-family: var(--sans);
    font-size: 19px;
    font-weight: 600;
    line-height: 1.25;
    color: var(--fg);
    margin: 0;
  }
  .adds-body {
    font-size: 14.5px;
    line-height: 1.6;
    color: var(--fg-body);
    margin: 0;
  }
  .adds-meta {
    margin-top: auto;
    padding-top: 14px;
    border-top: 1px solid var(--line-hairline);
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.04em;
    color: var(--fg-dim);
  }
  .adds-meta :global(.hl) {
    color: var(--accent);
  }

  /* ---------- BENCHMARKS ---------- */
  .bench-wrap {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 48px;
  }
  .bench-chart {
    background: var(--bg);
    border: 1px solid var(--line-strong);
    padding: 28px;
  }
  .bench-chart h4 {
    font-family: var(--mono);
    font-size: 12px;
    color: var(--fg);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: 24px;
    font-weight: 500;
  }
