---
import BaseLayout from '@/layouts/BaseLayout.astro';
---

<BaseLayout title="fail2zig — intrusion prevention, rebuilt" activeNav="/">
  <header class="hero">
    <div class="wrap">
      <div class="hero-grid">
        <div>
          <div class="hero-status">
            <span class="pulse"></span>
            <span>PREVIEW · Phase 1 pre-release · est. Q2 2026</span>
          </div>
          <h1>
            Intrusion prevention,<br />
            built for the<br />
            <span class="accent">next 20 years.</span>
          </h1>
          <p class="hero-lede">
            fail2zig picks up where fail2ban's 20-year legacy left off — written in Zig, shipped as
            a single static binary, with zero runtime dependencies and a parser that can't be made
            to allocate unbounded memory by the traffic it's supposed to be stopping.
          </p>
          <div class="hero-cta">
            <a href="/install" class="btn primary">$ Install fail2zig &nbsp;&rarr;</a>
            <a href="/security" class="btn ghost">Read the threat model</a>
          </div>
          <div class="hero-metrics">
            <div class="hero-metric">
              <div class="n">5.96M</div>
              <div class="l">lines/sec parsed</div>
            </div>
            <div class="hero-metric">
              <div class="n">932ns</div>
              <div class="l">ban decision p99</div>
            </div>
            <div class="hero-metric">
              <div class="n">877KB</div>
              <div class="l">static binary</div>
            </div>
            <div class="hero-metric">
              <div class="n">0</div>
              <div class="l">runtime deps</div>
            </div>
          </div>
        </div>

        <div class="diagram" aria-hidden="true">
          <div class="diagram-header">
            <div class="dots"><span></span><span></span><span></span></div>
            <div>pipeline.trace&nbsp;&middot;&nbsp;live</div>
            <div id="diag-counter">982,684 events</div>
          </div>
          <svg class="diagram-svg" viewBox="0 0 560 540" preserveAspectRatio="xMidYMid meet">
            <defs>
              <marker
                id="arrowhead"
                markerWidth="10"
                markerHeight="10"
                refX="9"
                refY="5"
                orient="auto"
              >
                <path d="M0,0 L10,5 L0,10 z" fill="var(--fg-mute)"></path>
              </marker>
              <linearGradient id="pulseGrad" x1="0" y1="0" x2="1" y2="0">
                <stop offset="0%" stop-color="var(--accent)" stop-opacity="0"></stop>
                <stop offset="50%" stop-color="var(--accent)" stop-opacity="1"></stop>
                <stop offset="100%" stop-color="var(--accent)" stop-opacity="0"></stop>
              </linearGradient>
            </defs>

            <text
              x="50"
              y="52"
              fill="var(--fg-mute)"
              font-family="var(--mono)"
              font-size="10"
              letter-spacing="1">01 &middot; SOURCE</text
            >
            <g class="node" data-stage="0">
              <rect x="40" y="70" width="200" height="90" fill="var(--bg)" stroke="var(--line)"
              ></rect>
              <text
                x="54"
                y="92"
                fill="var(--fg)"
                font-family="var(--mono)"
                font-size="12"
                font-weight="500">log sources</text
              >
              <text x="54" y="112" fill="var(--fg-dim)" font-family="var(--mono)" font-size="11"
                >/var/log/auth.log</text
              >
              <text x="54" y="128" fill="var(--fg-dim)" font-family="var(--mono)" font-size="11"
                >journald &middot; sshd &middot; nginx</text
              >
              <text x="54" y="148" fill="var(--fg-mute)" font-family="var(--mono)" font-size="10"
                >inotify &middot; io_uring &middot; kqueue</text
              >
            </g>

            <line
              x1="140"
              y1="160"
              x2="140"
              y2="200"
              stroke="var(--line)"
              stroke-width="1"
              marker-end="url(#arrowhead)"></line>
            <line
              id="wire1"
              x1="140"
              y1="160"
              x2="140"
              y2="200"
              stroke="url(#pulseGrad)"
              stroke-width="2"
              stroke-dasharray="40 600"
              stroke-dashoffset="0"></line>

            <text
              x="50"
              y="220"
              fill="var(--fg-mute)"
              font-family="var(--mono)"
              font-size="10"
              letter-spacing="1">02 &middot; PARSE</text
            >
            <g class="node" data-stage="1">
              <rect x="40" y="235" width="200" height="90" fill="var(--bg)" stroke="var(--line)"
              ></rect>
              <text
                x="54"
                y="257"
                fill="var(--fg)"
                font-family="var(--mono)"
                font-size="12"
                font-weight="500">parser engine</text
              >
              <text x="54" y="277" fill="var(--fg-dim)" font-family="var(--mono)" font-size="11"
                >comptime filters &middot; SIMD scan</text
              >
              <text x="54" y="293" fill="var(--fg-dim)" font-family="var(--mono)" font-size="11"
                >zero-copy &middot; bounds-checked</text
              >
              <text x="54" y="313" fill="var(--fg-mute)" font-family="var(--mono)" font-size="10"
                >no regex engine in-process</text
              >
            </g>

            <line
              x1="240"
              y1="280"
              x2="320"
              y2="280"
              stroke="var(--line)"
              stroke-width="1"
              marker-end="url(#arrowhead)"></line>
            <line
              id="wire2"
              x1="240"
              y1="280"
              x2="320"
              y2="280"
              stroke="url(#pulseGrad)"
              stroke-width="2"
              stroke-dasharray="30 400"></line>

            <text
              x="330"
              y="220"
              fill="var(--fg-mute)"
              font-family="var(--mono)"
              font-size="10"
              letter-spacing="1">03 &middot; STATE</text
            >
            <g class="node" data-stage="2">
              <rect x="320" y="235" width="200" height="90" fill="var(--bg)" stroke="var(--line)"
              ></rect>
              <text
                x="334"
                y="257"
                fill="var(--fg)"
                font-family="var(--mono)"
                font-size="12"
                font-weight="500">state tracker</text
              >
              <text x="334" y="277" fill="var(--fg-dim)" font-family="var(--mono)" font-size="11"
                >fixed-arena hash table</text
              >
              <text x="334" y="293" fill="var(--fg-dim)" font-family="var(--mono)" font-size="11"
                >pre-allocated &middot; evict-oldest</text
              >
              <text x="334" y="313" fill="var(--fg-mute)" font-family="var(--mono)" font-size="10"
                >hard 64MB ceiling</text
              >
            </g>

            <line
              x1="420"
              y1="325"
              x2="420"
              y2="365"
              stroke="var(--line)"
              stroke-width="1"
              marker-end="url(#arrowhead)"></line>
            <line
              id="wire3"
              x1="420"
              y1="325"
              x2="420"
              y2="365"
              stroke="url(#pulseGrad)"
              stroke-width="2"
              stroke-dasharray="20 300"></line>

            <text
              x="330"
              y="385"
              fill="var(--fg-mute)"
              font-family="var(--mono)"
              font-size="10"
              letter-spacing="1">04 &middot; BAN</text
            >
            <g class="node" data-stage="3">
              <rect x="320" y="400" width="200" height="90" fill="var(--bg)" stroke="var(--line)"
              ></rect>
              <text
                x="334"
                y="422"
                fill="var(--fg)"
                font-family="var(--mono)"
                font-size="12"
                font-weight="500">ban executor</text
              >
              <text x="334" y="442" fill="var(--fg-dim)" font-family="var(--mono)" font-size="11"
                >nftables &middot; ipset &middot; iptables</text
              >
              <text x="334" y="458" fill="var(--fg-dim)" font-family="var(--mono)" font-size="11"
                >eBPF/XDP (phase 2)</text
              >
              <text x="334" y="478" fill="var(--accent)" font-family="var(--mono)" font-size="10"
                >DROP &middot; at NIC driver</text
              >
            </g>

            <line
              x1="240"
              y1="450"
              x2="320"
              y2="450"
              stroke="var(--line-soft)"
              stroke-width="1"
              stroke-dasharray="3 3"></line>
            <g>
              <rect
                x="40"
                y="400"
                width="200"
                height="90"
                fill="var(--bg)"
                stroke="var(--line-soft)"
                stroke-dasharray="3 3"></rect>
              <text
                x="54"
                y="422"
                fill="var(--fg-dim)"
                font-family="var(--mono)"
                font-size="12"
                font-weight="500">metrics &middot; audit</text
              >
              <text x="54" y="442" fill="var(--fg-mute)" font-family="var(--mono)" font-size="11"
                >prometheus /metrics</text
              >
              <text x="54" y="458" fill="var(--fg-mute)" font-family="var(--mono)" font-size="11"
                >signed audit trail</text
              >
              <text x="54" y="478" fill="var(--fg-mute)" font-family="var(--mono)" font-size="10"
                >read-only endpoint</text
              >
            </g>

            <circle id="event" r="4" fill="var(--accent)" opacity="1" cx="140" cy="235">
              <animate attributeName="opacity" values="0;1;1;0" dur="3.2s" repeatCount="indefinite"
              ></animate>
            </circle>
          </svg>
        </div>
      </div>
    </div>
  </header>

  <!-- WHAT WE ADD -->
  <section class="section">
    <div class="wrap">
      <div class="section-head">
        <div class="eyebrow"><span class="dot"></span>01 &middot; What we add</div>
        <div>
          <h2>
            Built on 20 years of fail2ban's foundation &mdash; with a smaller, faster, safer TCB.
          </h2>
          <p class="lede" style="margin-top:16px">
            fail2ban has protected more internet-facing servers than almost any other tool. fail2zig
            builds on that lineage with a single static binary, explicit memory bounds, and a
            compile-time parser that eliminates an entire class of runtime risk.
          </p>
        </div>
      </div>

      <div class="problem-grid">
        <div class="problem-card">
          <h3>Smaller attack surface</h3>
          <p>
            ~12K lines of Zig versus ~45K lines of Python + CPython runtime + stdlib + C extensions.
            A smaller trusted computing base means fewer places for bugs to hide.
          </p>
          <div class="meta">~12K LOC &middot; no interpreter &middot; no VM</div>
        </div>
        <div class="problem-card">
          <h3>Bounded memory</h3>
          <p>
            A hard, configurable ceiling the daemon never exceeds &mdash; regardless of attack
            volume. Eviction policy is operator-defined. No garbage collector in the loop.
          </p>
          <div class="meta">hard ceiling &middot; configurable &middot; eviction policy</div>
        </div>
        <div class="problem-card">
          <h3>Higher throughput</h3>
          <p>
            Comptime-generated parsers with SIMD acceleration. Measured at 5.96M lines/sec on a Xeon
            E-2386G &mdash; keeping pace with busy SSH, postfix, and nginx log streams.
          </p>
          <div class="meta">5.96M l/s measured &middot; SIMD &middot; zero-alloc hot path</div>
        </div>
        <div class="problem-card">
          <h3>Instant readiness</h3>
          <p>
            No interpreter startup, no import chain. The daemon is accepting log events within
            milliseconds of exec. After a reboot, the gap where nothing is banning is as short as
            the kernel allows.
          </p>
          <div class="meta">no import cost &middot; no rule-compile cost</div>
        </div>
        <div class="problem-card">
          <h3>Runs anywhere</h3>
          <p>
            Static musl binary. Works on distroless containers, scratch images, hardened minimal
            servers, embedded Linux, OpenWrt routers &mdash; anywhere a Python runtime is
            unacceptable.
          </p>
          <div class="meta">musl &middot; 4 architectures &middot; no runtime</div>
        </div>
        <div class="problem-card">
          <h3>Clean config</h3>
          <p>
            Native TOML with strict validation &mdash; unknown keys are errors, not silent no-ops.
            <code>--import-config</code> migrates your existing fail2ban tree, translating jails and filters
            automatically.
          </p>
          <div class="meta">validated &middot; documented &middot; import path</div>
        </div>
      </div>
    </div>
  </section>

  <!-- BENCHMARKS -->
  <section class="section" id="benchmarks">
    <div class="wrap">
      <div class="section-head">
        <div class="eyebrow"><span class="dot"></span>02 &middot; Benchmarks</div>
        <div>
          <h2>Measured, not marketing.</h2>
          <p class="lede" style="margin-top:16px">
            All figures from Phase 7.5 real-system validation on a Xeon E-2386G. Reproducible
            benchmark suite ships with the source tree at <code>tests/benchmark/</code>.
          </p>
        </div>
      </div>

      <div class="bench-wrap">
        <div class="bench-chart">
          <h4>Parse throughput &middot; auth.log &middot; Xeon E-2386G</h4>
          <div class="bench-bar-row">
            <span class="bench-label">fail2ban</span>
            <div class="bench-bar">
              <div class="fill dim" data-w="0.007" style="width: 0.007%;"></div>
            </div>
            <span class="bench-val">~420 l/s</span>
          </div>
          <div class="bench-bar-row">
            <span class="bench-label">SSHGuard</span>
            <div class="bench-bar">
              <div class="fill dim" data-w="0.05" style="width: 0.05%;"></div>
            </div>
            <span class="bench-val">~3.1k l/s</span>
          </div>
          <div class="bench-bar-row">
            <span class="bench-label">CrowdSec</span>
            <div class="bench-bar">
              <div class="fill dim" data-w="0.08" style="width: 0.08%;"></div>
            </div>
            <span class="bench-val">~4.9k l/s</span>
          </div>
          <div class="bench-bar-row">
            <span class="bench-label">fail2zig</span>
            <div class="bench-bar">
              <div class="fill accent" data-w="100" style="width: 100%;"></div>
            </div>
            <span class="bench-val accent">5.96M l/s</span>
          </div>
          <div class="bench-note">
            Measured: Phase 7.5 ReleaseSafe build, <code>tests/benchmark/parse_throughput.zig</code
            >. Bars scale linearly. Reproduction guide in <a
              href="/docs"
              style="color:var(--accent)">tests/benchmark/README.md</a
            >.
          </div>
        </div>

        <div class="bench-chart">
          <h4>Memory under attack &middot; 50K unique IPs &middot; sustained</h4>
          <div class="bench-bar-row">
            <span class="bench-label">fail2ban</span>
            <div class="bench-bar">
              <div class="fill dim" data-w="88" style="width: 88%;"></div>
            </div>
            <span class="bench-val">~740 MB</span>
          </div>
          <div class="bench-bar-row">
            <span class="bench-label">CrowdSec</span>
            <div class="bench-bar">
              <div class="fill dim" data-w="32" style="width: 32%;"></div>
            </div>
            <span class="bench-val">~210 MB</span>
          </div>
          <div class="bench-bar-row">
            <span class="bench-label">SSHGuard</span>
            <div class="bench-bar">
              <div class="fill dim" data-w="10" style="width: 10%;"></div>
            </div>
            <span class="bench-val">~58 MB</span>
          </div>
          <div class="bench-bar-row">
            <span class="bench-label">fail2zig</span>
            <div class="bench-bar">
              <div class="fill accent" data-w="9" style="width: 9%;"></div>
            </div>
            <span class="bench-val accent">&le;64 MB *</span>
          </div>
          <div class="bench-note">
            * Hard ceiling, configurable. Under a 50K unique-IP attack: 21,845 resident entries +
            15,606 evicted. The daemon never exceeded the cap. Eviction policy is operator-defined.
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ARCHITECTURE / FEATURES -->
  <section class="section" id="architecture">
    <div class="wrap">
      <div class="section-head">
        <div class="eyebrow"><span class="dot"></span>03 &middot; Architecture</div>
        <div>
          <h2>Six components. One binary. Every allocation accounted for.</h2>
          <p class="lede" style="margin-top:16px">
            A straight pipeline &mdash; log in, ban out &mdash; with explicit allocator boundaries
            at every stage. No hidden work, no implicit runtime, no third-party code in the critical
            path.
          </p>
        </div>
      </div>

      <div class="feature-grid">
        <div class="feature">
          <div class="idx">01 / LOG WATCHER</div>
          <h3>Event-driven, rotation-aware</h3>
          <p>
            inotify on Linux, kqueue on BSD, sd_journal for systemd, io_uring for high-throughput
            batched I/O on 5.1+. Handles rename, truncate, and new-file creation without missing
            events.
          </p>
          <div class="meta">linux &middot; bsd &middot; journald &middot; stdin</div>
        </div>
        <div class="feature">
          <div class="idx">02 / PARSER ENGINE</div>
          <h3>Comptime filters, zero-copy</h3>
          <p>
            Built-in filters compile to specialised parsers at build time &mdash; no runtime regex
            engine in process. SIMD-accelerated IP extraction and timestamp parsing where the CPU
            supports it.
          </p>
          <div class="meta">no pcre &middot; no allocations/line &middot; simd</div>
        </div>
        <div class="feature">
          <div class="idx">03 / STATE TRACKER</div>
          <h3>Fixed-size arena, hard ceiling</h3>
          <p>
            Pre-allocated buckets, no dynamic resizing under load, configurable max with explicit
            eviction policy. Memory usage has a hard cap regardless of attack volume.
          </p>
          <div class="meta">evict-oldest &middot; ban-all &middot; drop-unbanned</div>
        </div>
        <div class="feature">
          <div class="idx">04 / BAN EXECUTOR</div>
          <h3>Pluggable firewall backends</h3>
          <p>
            nftables, iptables, ipset on day one. eBPF/XDP in Phase 2 &mdash; drops packets at the
            NIC driver level before they reach the kernel TCP stack. pf for BSD.
          </p>
          <div class="meta">nftables &middot; ipset &middot; xdp &middot; pf</div>
        </div>
        <div class="feature">
          <div class="idx">05 / CONFIG</div>
          <h3>Native + fail2ban-compatible</h3>
          <p>
            Native fail2zig.toml for new deployments. A dedicated parser reads jail.conf,
            jail.local, filter.d, action.d. The <code style="color:var(--accent)"
              >--import-config</code
            > flag converts your existing fail2ban tree.
          </p>
          <div class="meta">validated &middot; documented &middot; hot-reload (ph.2)</div>
        </div>
        <div class="feature">
          <div class="idx">06 / METRICS</div>
          <h3>Prometheus, out of the box</h3>
          <p>
            Built-in HTTP metrics endpoint &mdash; bind-restricted, read-only. Ban rate, parse
            throughput, active bans, per-jail stats. Structured JSON logs; syslog optional.
          </p>
          <div class="meta">/metrics &middot; structured &middot; signed-audit</div>
        </div>
      </div>
    </div>
  </section>

  <!-- COMPARISON -->
  <section class="section">
    <div class="wrap">
      <div class="section-head">
        <div class="eyebrow"><span class="dot"></span>04 &middot; Landscape</div>
        <div>
          <h2>What's out there, and what's different.</h2>
          <p class="lede" style="margin-top:16px">
            Not every IPS is trying to solve the same problem. fail2zig is a local-first,
            zero-dependency, zero-cloud alternative &mdash; a single binary you scp to a server and
            forget about.
          </p>
        </div>
      </div>

      <table class="cmp-table">
        <thead>
          <tr>
            <th style="width:140px">&nbsp;</th>
            <th>Language</th>
            <th>Deployment</th>
            <th>Banning</th>
            <th>Throughput</th>
            <th>Footprint</th>
          </tr>
        </thead>
        <tbody>
          <tr>
            <td class="row-head">fail2ban</td>
            <td class="dim">Python 3</td>
            <td class="dim">pkg + runtime</td>
            <td class="dim">iptables / nftables</td>
            <td class="dim">~hundreds l/s</td>
            <td class="dim">GC &middot; unbounded</td>
          </tr>
          <tr>
            <td class="row-head">SSHGuard</td>
            <td class="dim">C</td>
            <td class="dim">single binary</td>
            <td class="dim">pf / iptables / nftables</td>
            <td class="dim">medium</td>
            <td class="dim">small, SSH-focused</td>
          </tr>
          <tr>
            <td class="row-head">CrowdSec</td>
            <td class="dim">Go</td>
            <td class="dim">binary + cloud API</td>
            <td class="dim">iptables / nftables</td>
            <td class="dim">medium-high</td>
            <td class="dim">heavy &middot; cloud dep</td>
          </tr>
          <tr>
            <td class="row-head us">fail2zig</td>
            <td style="color:var(--fg)">Zig</td>
            <td style="color:var(--fg)">static binary, musl</td>
            <td style="color:var(--fg)">nft &middot; ipset &middot; eBPF/XDP &middot; pf</td>
            <td style="color:var(--accent)">5.96M l/s (measured)</td>
            <td style="color:var(--accent)">fixed ceiling &middot; 0 deps</td>
          </tr>
        </tbody>
      </table>
    </div>
  </section>

  <!-- INSTALL -->
  <section class="section" id="install">
    <div class="wrap">
      <div class="section-head">
        <div class="eyebrow"><span class="dot"></span>05 &middot; Install</div>
        <div>
          <h2>Two commands from fail2ban to fail2zig.</h2>
          <p class="lede" style="margin-top:16px">
            Drop the binary, import your existing config, restart the service. Migration is the
            adoption path.
          </p>
        </div>
      </div>

      <div class="install-grid">
        <div class="install-block">
          <div class="install-head">
            <span>terminal &middot; linux/x86_64</span>
            <button
              class="copy-btn"
              data-copy="curl -fsSL https://fail2zig.com/install.sh | sh
fail2zig --import-config /etc/fail2ban/"
              >copy</button
            >
          </div>
          <div class="install-body">
            <span class="cmt"># 1 — fetch the static binary (877 KB, musl-linked)</span><br />
            <span class="prompt">$</span> curl -fsSL https://fail2zig.com/install.sh | sh<br />
            <br />
            <span class="cmt"># 2 — migrate from fail2ban, review the generated config</span><br />
            <span class="prompt">$</span> fail2zig --import-config /etc/fail2ban/<br />
            <span style="color:var(--fg-mute)"
              >&rarr; translated 14 jails &middot; 2 warnings &middot; wrote /etc/fail2zig.toml</span
            ><br />
            <br />
            <span class="cmt"># 3 — swap the service</span><br />
            <span class="prompt">$</span> systemctl disable --now fail2ban<br />
            <span class="prompt">$</span> systemctl enable --now fail2zig<br />
          </div>
        </div>

        <div class="install-block">
          <div class="install-head">
            <span>targets &middot; stripped &middot; static</span>
            <span style="color:var(--fg-dim)">via github releases</span>
