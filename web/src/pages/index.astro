<script is:inline>
  // animate bench bars in on load
  document.addEventListener('DOMContentLoaded', function () {
    requestAnimationFrame(function () {
      document.querySelectorAll('.bench-bar .fill').forEach(function (el) {
        var w = el.getAttribute('data-w');
        el.style.width = w + '%';
      });
    });

    // copy button
    document.querySelectorAll('.copy-btn').forEach(function (btn) {
      btn.addEventListener('click', function () {
        var text = btn.getAttribute('data-copy');
        if (text) {
          navigator.clipboard.writeText(text.replace(/&#10;/g, '\n'));
          var orig = btn.textContent;
          btn.textContent = 'copied';
          setTimeout(function () {
            btn.textContent = orig;
          }, 1200);
        }
      });
    });

    // animated event dot through diagram
    var ev = document.getElementById('event');
    var counter = document.getElementById('diag-counter');
    if (ev) {
      var path = [
        [140, 90],
        [140, 160],
        [140, 235],
        [140, 280],
        [240, 280],
        [320, 280],
        [420, 280],
        [420, 325],
        [420, 400],
        [420, 445],
      ];
      var t = 0;
      var counterVal = 0;
      setInterval(function () {
        t = (t + 1) % path.length;
        var p = path[t];
        ev.setAttribute('cx', String(p[0]));
        ev.setAttribute('cy', String(p[1]));
        ev.setAttribute('opacity', '1');
        if (t === 0) {
          counterVal += Math.floor(18000 + Math.random() * 6000);
          if (counter) counter.textContent = counterVal.toLocaleString() + ' events';
        }
      }, 280);
    }
  });
</script>
