---
import BaseLayout from '@/layouts/BaseLayout.astro';
---

<BaseLayout
  title="fail2zig · privacy"
  description="Privacy policy for fail2zig."
  activeNav="/privacy"
>
  <article class="legal-stub">
    <div class="wrap">
      <div class="eyebrow"><span class="dot"></span>Privacy</div>
      <h1>Privacy policy</h1>
      <p class="lede">
        Full policy coming soon. Short version below.
      </p>
      <h2>What we collect</h2>
      <p>
        This site uses Cloudflare Web Analytics. It is cookieless and does not fingerprint
        visitors. Pageview counts, referrer domains, and coarse device class are aggregated
        at the edge. No personal data is collected or stored.
      </p>
      <h2>What the fail2zig daemon does</h2>
      <p>
        The daemon runs on your own servers. It reads your log files, maintains ban state on
        disk, and writes firewall rules. It does not send telemetry or call home.
      </p>
      <p class="stub-note">Last updated: draft, expanded version pending.</p>
    </div>
  </article>
</BaseLayout>

<style>
  .legal-stub {
    padding: 96px 0 128px;
  }
  .legal-stub h1 {
    font-size: clamp(32px, 3.4vw, 44px);
    line-height: 1.08;
    letter-spacing: -0.02em;
    margin: 20px 0 16px;
  }
  .legal-stub .lede {
    margin-bottom: 40px;
  }
  .legal-stub h2 {
    font-family: var(--mono);
    font-size: 15px;
    font-weight: 500;
    color: var(--fg);
    margin: 32px 0 12px;
  }
  .legal-stub p {
    color: var(--fg-body);
    line-height: 1.65;
    max-width: 68ch;
    margin: 0 0 14px;
  }
  .stub-note {
    margin-top: 48px;
    padding-top: 20px;
    border-top: 1px dashed var(--line);
    color: var(--fg-dim);
    font-family: var(--mono);
    font-size: 12px;
  }
</style>
